# Production environment for the devlog backend.
#
# Copy this to `backend.env` in the deploy directory on the VPS (default
# /opt/devlog-backend/backend.env) and fill in real values. It holds SECRETS —
# keep it 0600 and NEVER commit the filled-in version.

PORT=8080

# --- Database: MySQL --------------------------------------------------------
DB_DRIVER=mysql
# Full MySQL DSN, INCLUDING the DB password, in this format:
#   devlog:PASSWORD@tcp(HOST:3306)/devlog?parseTime=true&loc=UTC
# parseTime=true & loc=UTC are required. Add tls=true for managed DBs that
# enforce TLS (tls=skip-verify for self-signed certs).
# The password is used literally — do NOT URL-encode it. The only character that
# breaks the DSN is '/', so avoid it in the DB password.
#
# HOST depends on where MySQL lives. The backend runs in a container, so never use
# 127.0.0.1 (that's the container itself). Instead:
#   - MySQL on THIS VPS (a container publishing 3306, or native on the host):
#       host.docker.internal   (resolved via extra_hosts in docker-compose.prod.yml)
#   - External / managed MySQL:  its real hostname or IP
DB_DSN=devlog:CHANGE_ME@tcp(host.docker.internal:3306)/devlog?parseTime=true&loc=UTC

# --- Sessions --------------------------------------------------------------
# Generate with: openssl rand -base64 32
SESSION_SECRET=CHANGE_ME
# true when the backend is served over HTTPS (e.g. behind a reverse proxy) so
# the session cookie gets the Secure flag.
COOKIE_SECURE=true

# Public origin of the frontend (Stripe redirects & links point back here).
APP_BASE_URL=https://your-frontend-domain

# --- Optional: IAM (OAuth2/OIDC) — leave blank to run anonymously ----------
# IAM_ISSUER_URL=
# IAM_TENANT_ID=
# IAM_CLIENT_ID=
# IAM_CLIENT_SECRET=

# --- Optional: Image uploads (Cloudflare R2 / any S3-compatible store) -----
# Leave blank to disable image uploads (the editor shows a localized error).
# See deployments/README.md ("Image uploads") for the R2 setup walkthrough.
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# S3_BUCKET=devlog-images
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# Public origin serving the bucket (R2 custom domain behind Cloudflare's CDN).
# Article bodies may only embed images under this origin.
# IMAGE_BASE_URL=https://img.your-domain

# --- Optional: Stripe (leave blank for the demo payment flow) --------------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- Optional: MoMo (leave blank for the demo payment flow) ----------------
# MOMO_PARTNER_CODE=
# MOMO_ACCESS_KEY=
# MOMO_SECRET_KEY=
# MOMO_CREATE_ENDPOINT=https://payment.momo.vn/v2/gateway/api/create
# MOMO_QUERY_ENDPOINT=https://payment.momo.vn/v2/gateway/api/query
