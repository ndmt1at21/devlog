# Port the HTTP server listens on
PORT=8080

# Storage backend: "memory" (zero-infra dev default) or "mysql".
DB_DRIVER=memory
# Required when DB_DRIVER=mysql. Note parseTime=true & loc=UTC.
# DB_DSN=devlog:devlog@tcp(localhost:3306)/devlog?parseTime=true&loc=UTC&multiStatements=true

# IAM (OAuth2/OIDC) integration — leave IAM_ISSUER_URL empty to disable auth.
# Tenant issuer / protocol base. In dev use the path fallback: http://localhost:8080/t/devnote
# IAM_ISSUER_URL=http://localhost:8080/t/devnote
# IAM_TENANT_ID=
# IAM_CLIENT_ID=
# IAM_CLIENT_SECRET=

# Session cookie signing/encryption secret (change in production).
SESSION_SECRET=dev-insecure-session-secret-change-me
# Set true behind HTTPS so the session cookie gets the Secure flag.
COOKIE_SECURE=false

# Public origin of the frontend; Stripe Checkout redirects back here.
APP_BASE_URL=http://localhost:3000

# --- "Buy me a coffee" payments (all optional) ---
# Leave keys empty to keep the demo flow (no real charge).
# Stripe (international Visa/Mastercard via Checkout). Test keys: https://dashboard.stripe.com/test/apikeys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# MoMo (Vietnam) sandbox: https://developers.momo.vn
# MOMO_PARTNER_CODE=MOMO...
# MOMO_ACCESS_KEY=...
# MOMO_SECRET_KEY=...
# MOMO_CREATE_ENDPOINT=https://test-payment.momo.vn/v3/gateway/api/create
# MOMO_QUERY_ENDPOINT=https://test-payment.momo.vn/v3/gateway/api/query
