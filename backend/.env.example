# Port the HTTP server listens on
PORT=8080

# Structured logging (log/slog). LOG_LEVEL: debug|info|warn|error.
# LOG_FORMAT: "text" (human-readable, dev) or "json" (log aggregation, prod).
LOG_LEVEL=info
LOG_FORMAT=text

# Storage backend: "memory" (zero-infra dev default) or "mysql".
DB_DRIVER=memory
# Required when DB_DRIVER=mysql. Note parseTime=true & loc=UTC.
# DB_DSN=devlog:devlog@tcp(localhost:3306)/devlog?parseTime=true&loc=UTC&multiStatements=true
# The server never seeds MySQL. To load the design's demo content into a fresh
# local DB, run the separate command: `make seed` (or `go run ./cmd/seed`).

# Auth is embedded (no external IAM service): accounts live in the blog's own
# store, passwords are argon2id-hashed, and the first registered account
# becomes the author (may publish articles). Nothing to configure for
# email/password login.
#
# "Đăng nhập với Google" (federated login) needs a Google OAuth client
# (https://console.cloud.google.com/apis/credentials). Leave empty to disable.
# Register the authorized redirect URI on that client:
#   {APP_BASE_URL}/api/v1/auth/google/callback
#   (e.g. http://localhost:3000/api/v1/auth/google/callback)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Session cookie signing/encryption secret (change in production).
SESSION_SECRET=dev-insecure-session-secret-change-me
# Set true behind HTTPS so the session cookie gets the Secure flag.
COOKIE_SECURE=false

# Public origin of the frontend; Stripe Checkout redirects back here.
APP_BASE_URL=http://localhost:3000

# --- "Buy me a coffee" payments (all optional) ---
# Leave keys empty to keep the demo flow (no real charge).
# Stripe (international Visa/Mastercard via Checkout). Test keys: https://dashboard.stripe.com/test/apikeys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# MoMo (Vietnam) sandbox: https://developers.momo.vn
# MOMO_PARTNER_CODE=MOMO...
# MOMO_ACCESS_KEY=...
# MOMO_SECRET_KEY=...
# MOMO_CREATE_ENDPOINT=https://test-payment.momo.vn/v3/gateway/api/create
# MOMO_QUERY_ENDPOINT=https://test-payment.momo.vn/v3/gateway/api/query
